{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default SkiLens desktop capability",
  "windows": ["main"],
    "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:default",
    "log:default",
    "opener:default",
    "store:default",
    "window-state:default",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/.claude/skills/**",
        "$HOME/.cc-switch/skills/**",
        "$HOME/.agents/skills/**",
        "$HOME/.codex/skills/**",
        "$HOME/.config/opencode/skills/**",
        "$HOME/Library/Application Support/skills-stats/**",
        "$HOME/.Trash/skills-stats/**"
      ]
    }
  ]
}

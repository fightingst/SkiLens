{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkiLens",
  "version": "0.1.0",
  "identifier": "com.skilens.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkiLens",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "shortDescription": "Skill usage dashboard",
    "longDescription": "SkiLens scans local Claude Code skill usage logs and shows usage analytics."
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
